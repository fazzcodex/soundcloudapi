{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/docs", "dest": "/public/docs.html" },
    { "src": "/(.*)", "dest": "/index.js" }
  ]
}
